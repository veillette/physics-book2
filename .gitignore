/resources/*.dbk
/resources/*.jar
/resources/unifiedfile*
/resources/*.html
/resources/*.txt
/node_modules
/zips


/.ipynb_checkpoints/

# Ignore metadata generated by Jekyll
/_site/
/.jekyll-cache/
/.jekyll-metadata

# Eleventy migration (migrate/eleventy branch): frozen Jekyll parity baseline
# is a build artifact. src/contents/ holds the P5 converter's generated markdown
# (also a build artifact) — but its committed directory-data config lives there
# too, so ignore only the generated *.md, not the .11tydata.js.
/_site_jekyll_baseline/
/src/contents/*.md
/src/SUMMARY.md

# Ignore folders generated by Bundler
/.bundle/
/vendor/
/bin/

# Ignore intellij
/.idea/
/.mypy_cache/
__pycache__/

# Generated PDF output (build artifacts — produced by scripts/generate-pdf.js
# and the generate-pdfs workflow; not tracked to keep the repo small)
/pdf-output/
/assets/pdf/

# Link checker cache
.link-cache.json
